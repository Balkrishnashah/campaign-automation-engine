 placeholder_list = catx(',',placeholder_list, '"'|| strip(PLACEHOLDER3) || '"');


 if _n_ = 1 then do;
 put '{';
 put '"messages":[';
 end;
 put '{';
 put '"from":' sender_val +(-1)',';
 put '"to":' receiver_val+(-1)',';
 put '"messageId":' MESSAGE_ID_val+(-1)',';
 put '"content" : {';
 put '"templateName":' wa_temp_val+(-1)',';
 put '"templateData" :{';
 put '"body": {';
 
 if not missing(placeholder_list) then do;
 put '"placeholders":[' placeholder_list +(-1) ']';
 end;
 else do;
 put '"placeholders":[]';
 end;
 
 put '}';
 put '},';
 put '"language":' LANGUAGE_val+(-1);
 put '},';
 put '"callbackData": ""';
 if last then put ' }';
 else put ' },';
 if last then do;
