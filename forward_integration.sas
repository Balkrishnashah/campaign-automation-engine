getnames=yes;
guessingrows=max;
run;

/*%let sftp_channel=facebook;*/
proc sql;
select compress(sftp_host) into : sftp_host from work.&lookup_output
where upcase(channel_name) = upcase(strip("&sftp_channel"))
and upcase(file_type) = 'LEAD';
select compress(sftp_user) into : sftp_user from work.&lookup_output
where upcase(channel_name) = upcase(strip("&sftp_channel"))
and upcase(file_type) = 'LEAD';
select strip(sftp_path) into : sftp_path from work.&lookup_output
where upcase(channel_name) = upcase(strip("&sftp_channel"))
and upcase(file_type) = 'LEAD';
quit;

%put === after compress ====;
%let sftp_host = %sysfunc(compress(&sftp_host));
%put &=sftp_host;

%let sftp_user = %sysfunc(compress(&sftp_user));
%put &=sftp_user;


%put ========= SFTP Details for the file transfer =========;
%put &=campaign_id;
%put &=sftp_channel;
%put &=sftp_path;
