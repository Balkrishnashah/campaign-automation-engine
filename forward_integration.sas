/* Description : IAP : Transfer to IAP channel */

%macro send_to_iap_v2(dataset=, iap_task_id=, iap_segment_id=);

/* Define the destination URL : not in use*/
/*%let iap_endpoint = "https://10.119.38.119:8443/notification/promo/broadcast";*/

/* Define the HTTP headers */
/*old proxy 10.255.16.35:8999 */
%put inside iap api loop;
%let iap_auth_path = &iap_token_path.&iap_token_filenm;

filename iapauth "&iap_auth_path";

/*extract authentication info from the iap auth file */
data _null_;
infile iapauth lrecl=32767 truncover;
input;
if _N_ = 1 then do;
call symput('iap_endpoint',strip(_infile_));
end;
else do;
call symput('iap_bearer_token',strip(_infile_));
end;
run;

%put &=iap_endpoint;
%put &=iap_bearer_token;


/*generate a unique id as per the IAP */
data _null_;
uuid = UUIDGEN();
call symputx('new_request_id', uuid);
run;

/*generate the authentication header fro the api */
filename headers temp;
data _null_;
	file headers;
	put 'accept: application/json';
	put 'X-CLIENT-ID:'"&iap_x_client_id";
	put 'X-CHANNEL:'"&iap_x_channel";
	put 'X-REQUEST-ID:' "&new_request_id";
	put 'Authorization: Bearer ' "&iap_bearer_token";
	put 'Content-Type: application/json';
run;

/*print auth header in log */
%echofile(headers);

/*filename payload &UtilityLocation.iap_forward/payload.json;*/

/* Create the JSON payload dynamically 
based on the customer data */


/*create number of iterations based on the total record count
API will process the records as per one iteration
*/

proc sql noprint; 
select ceil(count(*) / &maxiappayloadsize.) into : numIterations 
from &dataset;
quit;

/*below process will create payload and transfer payload to IAP channel */
%let iap_chunk = %sysevalf(&maxiappayloadsize);

%do i=1 %to &numIterations;
	%let startObs = %eval((&i - 1) * &iap_chunk + 1);
	%let endObs = %eval(&i * &iap_chunk);


/*create a dataset for current payload */
data iapcmdm_&i;
set work.&channelnm._CMDM (firstobs=&startObs obs=&endObs) ;
run;

	filename payload temp;

	data _null_;
		file payload;
		length json $32000;
		set iapcmdm_&i end=eof;

		if _n_ = 1 then do;
		json = cats('{
"messageId":"',MESSAGEID ,'",
"channelCode": "',CHANNELCODE,'",
"isfallback":true,
"srcBlastingMethod": "',SRCBLASTINGMETHOD,'",
"custDetail" :[');
	put json;
	end;

	json = cats('{
"cifId": "',CIFNO,'",
"refNumber": "',REFNUMBER,'",
"mobileNumber": "',MOBILENUMBER,'",
"email": "',EMAIL,'",
"smsGatewayMsgId": ""}');

if not eof then json = cats(json, ',');

put json;

if eof then do;
	json = cats('  ],
"en": {
"title": "',EN_TITLE,'",
"description": "',EN_DESCRIPTION,'",
"messageBody": "',EN_MESSAGE,'",
"imageUrl": "',EN_IMAGEURL,'",
"redirectUrl": "',EN_REDIRECTURL,'",
"promoType": "ALL",
"btnLabel": "',EN_BTN_LABEL,'"
},
"bm": {
"title": "',BM_TITLE,'",
"description": "',BM_DESCRIPTION,'",
"messageBody": "',BM_MESSAGE,'",
"imageUrl": "',BM_IMAGEURL,'",
"redirectUrl": "',BM_REDIRECTURL,'",
"promoType": "All",
"btnLabel": "',BM_BTN_LABEL,'"
},
"ch": {
"title": "',CH_TITLE,'",
"description": "',CH_DESCRIPTION,'",
"messageBody": "',CH_MESSAGE,'",
"imageUrl": "',CH_IMAGEURL,'",
"redirectUrl": "',CH_REDIRECTURL,'",
"promoType": "ALL",
"btnLabel": "',CH_BTN_LABEL,'"
}
}');

	put json;
	end;
run;

/*print the payload in log */
%echofile(payload);

filename response temp;


/* Send the HTTP request to trnasfer the payload to IAP  */
proc http
  url="&iap_endpoint"
  method='POST'
  out=response
  headerin=headers
  in=payload;
  SSLPARMS	
  "SSLREQCERT"="ALLOW"
;
run;

