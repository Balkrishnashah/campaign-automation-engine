put 'Valid channel Name ' channelnm=;
if upcase(file_extension)="CSV" and filenm_length<=25 then do;
call execute('%nrstr( %export_process(filenm = '||strip(file_name)||', filenm_shortnm='||strip(filenm_sortnm)||', channelnm= '||strip(channelnm)||' );) ');
