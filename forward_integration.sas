data _null_;
 set work.whatsapp_payload end=last;
 file payload lrecl=32767;
 sender_val = '"' || strip(sender) || '"';
 MESSAGE_ID_val = '"' || strip(MESSAGE_ID) || '"';
 LANGUAGE_val = '"' || strip(LANGUAGE) || '"';
 receiver_val = '"' || strip(receiver) || '"';
 PLACEHOLDER1_val = '"' || strip(PLACEHOLDER1) || '"';
 PLACEHOLDER2_val = '"' || strip(PLACEHOLDER2) || '"';
 PLACEHOLDER3_val = '"' || strip(PLACEHOLDER3) || '"';
 wa_temp_val = '"' || strip(WHATSAPPTEMPLATEID) || '"';
 
 length placeholder_list $32767;
placeholder_list = '';
if not missing(PLACEHOLDER1) and PLACEHOLDER1 ne '' then
 placeholder_list = catx(',',placeholder_list, '"'|| strip(PLACEHOLDER1) || '"');
if not missing(PLACEHOLDER2) and PLACEHOLDER2 ne '' then
 placeholder_list = catx(',',placeholder_list, '"'|| strip(PLACEHOLDER2) || '"');
