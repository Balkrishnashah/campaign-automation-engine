/*below will extract the status of last campaign execution
Main purpose of this step to check if the last campaign is still under process 
or executed successfully.
if last campaign executed the entire campaign process then the new campaign will be processed
*/
proc sql;
select remark into : max_job_status separated by ' ' 
from cmdmlib.campaign_audit
where id  = (select max(id) from 
cmdmlib.campaign_audit where
jobname = 'file_watcher_utility.sas')
and jobname = 'file_watcher_utility.sas'
order by insert_dttm ;
quit;

%put &=max_job_status;
/*variables to hold the status of audit jobs*/
%let sucess_status = START END;
%let error_status  = START ERROR;
%let exec_status   = START;

/*if max job status is equal to sucees_status then it will go for new file*/
%if %sysfunc(upcase(&max_job_status)) = &sucess_status %then %do;
%put Last job has end status going for new file processing;
/*data step to check for new files */

/*checkpoint execute_always for new campaign file in the directory and call for execution*/
data _null_;
did = dopen('export');
put did=;
do i=1 to dnum(did);
file_name = dread(did, i);
file_extension = substr(dread(did,i),index(dread(did,i),'.')+1,length(dread(did,i)));
filenm_sortnm = substr(dread(did,i),1,index(dread(did,i),'.')-1);
channelnm = scan(file_name, 1, '_');
put file_name= file_extension= filenm_sortnm= channelnm=;
filenm_length = length(filenm_sortnm);
if upcase(channelnm) in ('SMS', 'ATLAS','DIRECTSALES','TELEDIRECTMSIG','TELEDIRECTHLA','EDM','WHATSAPP','DIRECTMAILER','HLWP','LMS','IAP','HLA','TELEDIRECTHLA','STARTEK','FACEBOOK') then do;
put 'Valid channel Name ' channelnm=;
if upcase(file_extension)="CSV" and filenm_length<=25 then do;
call execute('%nrstr( %export_process(filenm = '||strip(file_name)||', filenm_shortnm='||strip(filenm_sortnm)||', channelnm= '||strip(channelnm)||' );) ');
end;
else do;
put 'Either file length is bigger then 25 or it is no in CSV format';
end;

end;
else do;
put 'Invalid File Name! Error : Valid channel Name not found in file name';
put 'Channel Name found in File name :' channelnm=;
end;

end;
run;


%end;
%if %sysfunc(upcase(&max_job_status)) = &error_status %then %do;
%put Last campaign processed with errors;
%put Stopping the new execution to prevent new crashed;
/*send email alerts to IT to check for logs*/
/*it will throw and error in the log for last job if not processed successfully*/

