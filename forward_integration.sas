/*contact policy batch macro */

/* **************** code block #12  *************** */
/* Description : Contact Policy : contact policy Batch  */

%macro contact_policy_batch( dataset,eligible_col_nm, 
intd_flag, counter_col_nm, overall_col_nm );
%put ======== Start of Contact Policy Batch macro ======;
%put ======== Information received in contact policy macro ======;

%put dataset name : &dataset;
%put Eligible Column Name :  &eligible_col_nm;
%put Interdependency Flag : &intd_col_flag ;
%put Counter column Name : &counter_col_nm;
%put Overall Counter Column Name : &overall_counter_col_nm ;


/* query to create on prem table for faster execution*/
%let datetime = %sysfunc(compress(%sysfunc(datetime(),datetime20.),': '));
%let on_prem_tbl_nm = &filenm_shortnm.&datetime;

data TVEDWCM.&on_prem_tbl_nm;
set work.&dataset;
run;

%put NOTE: Table created -> &on_prem_tbl_nm;


/*create the first dataset by joining with contact policy table and extract required columns */
proc sql;
create table work.&filenm_shortnm._CP1 as
select a.*,
b.&eligible_col_nm,
b.&counter_col_nm,
b.&overall_counter_col_nm,
b.interdependency_eligibility
from TVEDWCM.&on_prem_tbl_nm a 
inner join  cmdmlib.contact_policy_batch b
on strip(a.cifno) = strip(b.cifno);
quit;

/*create flags as per contact policy logic */

proc sql;
create table 
work.&filenm_shortnm._CP2 as
select *, 
%if %sysfunc(lowcase(&intd_col_flag)) = yes %then %do;
case when upcase(interdependency_eligibility) = 'N' then 'IF' end as ig_flag,
%end;
%else %do;
'' as ig_flag,
%end;
case when &counter_col_nm <= 0 then 'CB' end as cb_flag,
case when &overall_counter_col_nm <= 0 then 'CC' end as cc_flag,
%if %sysfunc(lowcase(&eligible_col_flag)) = yes %then %do;
case when  upcase(&eligible_col_nm) = 'N' then 'CP' end as cp_flag
%end;
%else %do;
'' as cp_flag
%end;
from work.&filenm_shortnm._CP1;
quit;

/*
Based on the calculated flags create a contact code column to if there is no code 
in code any of flag columns then that customer will be marked as eligible
else the first code will be consider as disqualification criteria from contact policy 
*/

proc sql;
create table 
work.&filenm_shortnm._CP3 as
select *,
coalesce(
ig_flag,
cb_flag,
cc_flag,
cp_flag, 'ELIGIBLE') as contact_code
from
work.&filenm_shortnm._CP2;
quit;

/*create final dataset by removing all the flags columns and contact policy columns */

data work.&filenm_shortnm._CPF;
set work.&filenm_shortnm._CP3;
drop &eligible_col_nm &counter_col_nm &overall_counter_col_nm interdependency_eligibility;
drop ig_flag cb_flag cc_flag cp_flag;
run;

/*dropping the temp table from gaussdb */
proc sql;
drop table TVEDWCM.&on_prem_tbl_nm;
quit;

%mend;


/*contact policy realtime macro */

/* **************** code block #13  *************** */
/* Description : Contact Policy : contact policy Realtime  */

%macro contact_policy_realtime(dataset,contacted_col_nm,counter_col_nm, overall_col_nm, cooling_period_col_nm);

%put ======== Start of Contact Policy Realtime macro ======;
%put ======== Information received in contact policy macro ======;

%put dataset name : &dataset;
%put Contacted Column Name :  &contacted_col_nm;
%put Counter column Name : &counter_col_nm;
%put Overall Counter Column Name : &overall_counter_col_nm ;
%put cooling Period column Name : &cooling_period_col_nm;


/* query to create on prem table for faster execution*/
%let datetime = %sysfunc(compress(%sysfunc(datetime(),datetime20.),': '));
%let on_prem_tbl_nm = &filenm_shortnm.&datetime;

data TVEDWCM.&on_prem_tbl_nm;
set work.&dataset;
run;

%put NOTE: Table created -> &on_prem_tbl_nm;


/*create the first dataset by joining with contact policy table and extract required columns */

proc sql;
create table work.&filenm_shortnm._CP1 as
select a.*,
b.&contacted_col_nm,
b.&counter_col_nm,
b.&overall_counter_col_nm,
input(b.&cooling_period_col_nm,8.) as &cooling_period_col_nm
from TVEDWCM.&on_prem_tbl_nm a 
inner join  cmdmlib.contact_policy_rt b
on strip(a.cifno) = strip(b.cifno);
quit;


/*create flags as per contact policy logic */

proc sql;
create table 
work.&filenm_shortnm._CP2 as
select *, 
case when &counter_col_nm <= 0 then 'CR' end as cr_flag,
case when &overall_counter_col_nm <= 0 then 'CC' end as cc_flag,
case when  ceil((datetime() - &contacted_col_nm) / 3600) <= &cooling_period_col_nm 
then 'CP' end as cp_flag
from work.&filenm_shortnm._CP1;
quit;

/*
Based on the calculated flags create a contact code column to if there is no code 
in code any of flag columns then that customer will be marked as eligible
else the first code will be consider as disqualification criteria from contact policy 
*/


proc sql;
create table 
work.&filenm_shortnm._CP3 as
select *,
coalesce(
cr_flag,
cc_flag,
cp_flag, 'ELIGIBLE') as contact_code
from
work.&filenm_shortnm._CP2;
quit;

/*create final dataset by removing all the flags columns and contact policy columns */


data work.&filenm_shortnm._CPF;
set work.&filenm_shortnm._CP3;
drop &contacted_col_nm &counter_col_nm &overall_counter_col_nm &cooling_period_col_nm;
drop cr_flag cc_flag cp_flag;
run;

/*dropping the temp table from gaussdb */
proc sql;
drop table TVEDWCM.&on_prem_tbl_nm;
quit;

%mend;






